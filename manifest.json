// ─── API KEY MANAGEMENT ──────────────────────────────────────────────────────
const KEY_STORE = 'paris_guide_api_key';

function getApiKey(){ return localStorage.getItem(KEY_STORE)||'' }
function hasApiKey(){ return !!getApiKey() }

function openApiModal(){
  const k = getApiKey();
  document.getElementById('api-key-inp').value = k ? k : '';
  document.getElementById('api-status-msg').style.display='none';
  document.getElementById('api-overlay').classList.add('show');
  setTimeout(()=>document.getElementById('api-key-inp').focus(),300);
}
function closeApiModal(){
  document.getElementById('api-overlay').classList.remove('show');
}

function saveApiKey(){
  const val = document.getElementById('api-key-inp').value.trim();
  const statusEl = document.getElementById('api-status-msg');
  if(!val){
    statusEl.className='api-status err';
    statusEl.textContent='Wklej klucz API zaczynający się od sk-ant-...';
    statusEl.style.display='flex';
    return;
  }
  if(!val.startsWith('sk-ant-')){
    statusEl.className='api-status err';
    statusEl.textContent='Klucz powinien zaczynać się od "sk-ant-". Sprawdź czy skopiowałeś poprawnie.';
    statusEl.style.display='flex';
    return;
  }
  localStorage.setItem(KEY_STORE, val);
  statusEl.className='api-status ok';
  statusEl.textContent='✓ Klucz zapisany pomyślnie!';
  statusEl.style.display='flex';
  updateApiUI();
  setTimeout(closeApiModal, 1200);
}

function deleteApiKey(){
  if(confirm('Usunąć klucz API? Asystent AI przestanie działać.')){
    localStorage.removeItem(KEY_STORE);
    updateApiUI();
  }
}

function updateApiUI(){
  const has = hasApiKey();
  const key = getApiKey();
  // home indicator
  const ind = document.getElementById('home-api-status');
  const dot = document.getElementById('home-dot');
  const txt = document.getElementById('home-api-text');
  if(has){
    ind.className='api-indicator ok';
    dot.className='dot ok';
    txt.textContent='Klucz API aktywny';
  } else {
    ind.className='api-indicator missing';
    dot.className='dot missing';
    txt.textContent='Brak klucza API, kliknij by dodać';
  }
  // chat warning
  const warn = document.getElementById('no-key-warn');
  if(warn) warn.style.display = has ? 'none' : 'block';
  // settings page
  const kdisp = document.getElementById('key-display-wrap');
  const kmiss = document.getElementById('key-missing-wrap');
  if(kdisp && kmiss){
    if(has){
      kdisp.style.display='block';
      document.getElementById('key-display').textContent = key.slice(0,12)+'...'+key.slice(-6);
      kmiss.style.display='none';
    } else {
      kdisp.style.display='none';
      kmiss.style.display='block';
    }
  }
}

// ─── PWA INSTALL ─────────────────────────────────────────────────────────────
let deferredPrompt = null;

window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById('install-banner').classList.add('show');
  const btn = document.getElementById('install-btn-settings');
  if(btn) btn.style.display='block';
});

function triggerInstall(){
  if(deferredPrompt){
    deferredPrompt.prompt();
    deferredPrompt.userChoice.then(r=>{
      if(r.outcome==='accepted'){
        document.getElementById('install-banner').classList.remove('show');
      }
      deferredPrompt=null;
    });
  } else {
    goPage('page-settings');
  }
}

window.addEventListener('appinstalled',()=>{
  document.getElementById('install-banner').classList.remove('show');
  deferredPrompt=null;
});

// ─── NAVIGATION ──────────────────────────────────────────────────────────────
function goPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  const map={'page-home':'nav-home','page-phrases':'nav-phrases','page-chat':'nav-chat','page-tips':'nav-tips','page-settings':'nav-settings'};
  if(map[id]) document.getElementById(map[id]).classList.add('active');
}

// ─── PHRASES ─────────────────────────────────────────────────────────────────
function buildCats(){
  document.getElementById('cat-grid').innerHTML = CATEGORIES.map(c=>`
    <div class="cat-btn" onclick="showPhrases('${c.id}')">
      <div class="cat-icon">${c.icon}</div>
      <div style="font-weight:500;font-size:13px">${c.name}</div>
      <div class="cat-count">${PHRASES[c.id]?.length||0} zwrotów</div>
    </div>
  `).join('');
}

function showCats(){
  document.getElementById('phrases-cats').style.display='block';
  document.getElementById('phrases-detail').style.display='none';
  document.getElementById('search-inp').value='';
}

function showPhrases(id, fromSearch=false){
  const cat = CATEGORIES.find(c=>c.id===id);
  const phrases = PHRASES[id]||[];
  document.getElementById('cat-title').textContent = cat ? cat.name : 'Wyniki';
  document.getElementById('cat-sub').textContent = cat ? cat.sub : '';
  document.getElementById('phrase-items').innerHTML = phrases.map((p,i)=>`
    <div class="phrase-card" id="pc-${id}-${i}" onclick="toggleCard('${id}',${i})">
      <button class="speak-btn" onclick="event.stopPropagation();speak('${p.fr.replace(/'/g,"\\'").replace(/"/g,'&quot;')}')">▶</button>
      <div class="phrase-fr">${p.fr}</div>
      <div class="phrase-pl">${p.pl}</div>
      <div class="phrase-pron">/${p.pron}/</div>
      ${p.tip?`<div class="phrase-tip">💡 ${p.tip}</div>`:''}
    </div>
  `).join('');
  document.getElementById('phrases-cats').style.display='none';
  document.getElementById('phrases-detail').style.display='flex';
}

function filterPhrases(val){
  if(!val||val.length<2){showCats();return;}
  const q=val.toLowerCase();
  const results=Object.entries(PHRASES).flatMap(([id,arr])=>arr.map(p=>({...p,id})))
    .filter(p=>p.fr.toLowerCase().includes(q)||p.pl.toLowerCase().includes(q));
  const tempId='search_'+Date.now();
  PHRASES[tempId]=results;
  document.getElementById('cat-title').textContent=`Wyniki dla "${val}"`;
  document.getElementById('cat-sub').textContent=`${results.length} zwrotów`;
  document.getElementById('phrase-items').innerHTML = results.map((p,i)=>`
    <div class="phrase-card" id="pc-${tempId}-${i}" onclick="toggleCard('${tempId}',${i})">
      <button class="speak-btn" onclick="event.stopPropagation();speak('${p.fr.replace(/'/g,"\\'").replace(/"/g,'&quot;')}')">▶</button>
      <div class="phrase-fr">${p.fr}</div>
      <div class="phrase-pl">${p.pl}</div>
      <div class="phrase-pron">/${p.pron}/</div>
      ${p.tip?`<div class="phrase-tip">💡 ${p.tip}</div>`:''}
    </div>
  `).join('');
  document.getElementById('phrases-cats').style.display='none';
  document.getElementById('phrases-detail').style.display='flex';
}

function toggleCard(id,i){
  const el=document.getElementById(`pc-${id}-${i}`);
  el.classList.toggle('open');
}

// ─── SPEECH ──────────────────────────────────────────────────────────────────
function speak(text){
  if(!('speechSynthesis' in window)){alert('Twoja przeglądarka nie obsługuje wymowy.');return;}
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.lang='fr-FR'; u.rate=0.82; u.pitch=1;
  const voices=speechSynthesis.getVoices().filter(v=>v.lang.startsWith('fr'));
  if(voices.length) u.voice=voices[0];
  speechSynthesis.speak(u);
}
if('speechSynthesis' in window) speechSynthesis.getVoices();

// ─── AI CHAT ─────────────────────────────────────────────────────────────────
let chatHistory=[];
const SYS=`Jesteś ekspertem od języka francuskiego i asystentem podróżniczym dla polskiej rodziny w Paryżu.

KONTEKST RODZINY:
- Wyjazd: 17-22 kwietnia 2026, Paryż
- Baza: La Défense (dzielnica biznesowa)
- Rodzina: 2 dorosłych + Dominika (4 lata) + Kuba (8 lat)
- 20 kwietnia: Disneyland cały dzień
- Pogoda: ok. 14 stopni, pochmurnie, przelotny deszcz
- Preferencje: brak muzeów, spacery, parki, atrakcje dla dzieci

ZASADY ODPOWIEDZI:
- Odpowiadaj ZAWSZE po polsku
- Gdy podajesz zwrot po francusku użyj tego formatu:
  🇫🇷 [zwrot po francusku]
  👂 Wymowa: [fonetyka dla Polaka, np. "bon-żur"]
  🇵🇱 Znaczenie: [po polsku]
  💡 Kiedy użyć: [krótki praktyczny kontekst]
- Bądź konkretny, unikaj ogólników
- NIE używaj myślników, zastępuj je przecinkami lub nawiasami
- Uwzględniaj że Dominika 4 lata szybko się męczy i potrzebuje wind, nie schodów
- Kuba 8 lat może zapamiętać kilka zwrotów sam
- Gdy dajesz więcej zwrotów, ponumeruj je
- Podawaj praktyczne tipy specyficzne dla rodziny z małymi dziećmi`;

async function sendChat(){
  const inp=document.getElementById('chat-inp');
  const msg=inp.value.trim();
  if(!msg) return;
  const key=getApiKey();
  if(!key){openApiModal();return;}
  inp.value='';
  addMsg(msg,'user');
  chatHistory.push({role:'user',content:msg});
  const loadEl=addMsg('⏳ Piszę...','ai loading');
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1200,system:SYS,messages:chatHistory.slice(-12)})
    });
    if(!res.ok){
      const err=await res.json().catch(()=>({}));
      if(res.status===401){
        loadEl.textContent='❌ Nieprawidłowy klucz API. Sprawdź klucz w zakładce Ustawienia.';
        loadEl.classList.remove('loading');
        return;
      }
      throw new Error(err.error?.message||'Błąd API');
    }
    const data=await res.json();
    const reply=data.content?.[0]?.text||'Przepraszam, spróbuj ponownie.';
    loadEl.classList.remove('loading');
    loadEl.innerHTML=formatReply(reply);
    chatHistory.push({role:'assistant',content:reply});
  } catch(e){
    loadEl.classList.remove('loading');
    loadEl.innerHTML='❌ Błąd połączenia: '+e.message+'. Sprawdź internet i klucz API.';
  }
  loadEl.scrollIntoView({behavior:'smooth',block:'end'});
}

function formatReply(t){
  return t
    .replace(/\*\*(.*?)\*\*/g,'<strong style="color:var(--acc2)">$1</strong>')
    .replace(/\*(.*?)\*/g,'<em style="color:var(--green)">$1</em>')
    .replace(/\n/g,'<br>');
}

function addMsg(text,cls){
  const h=document.getElementById('chat-history');
  const d=document.createElement('div');
  d.className='msg '+(cls.includes('user')?'user':'ai')+(cls.includes('loading')?' loading':'');
  d.innerHTML=text;
  h.appendChild(d);
  h.scrollTop=h.scrollHeight;
  return d;
}

function quickSend(txt){
  document.getElementById('chat-inp').value=txt;
  sendChat();
}

// ─── SERVICE WORKER ───────────────────────────────────────────────────────────
if('serviceWorker' in navigator){
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
buildCats();
updateApiUI();
</script>
